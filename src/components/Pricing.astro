---
const plans = [
  {
    name: 'Starter',
    price: '2.400',
    period: 'pro Jahr',
    description: 'Für kleine Teams, die gezielt starten wollen.',
    features: [
      '3 wählbare Module',
      'Bis zu 10 Benutzer',
      'Multi-Standort',
      'PWA (mobil installierbar)',
      'E-Mail-Support',
    ],
    cta: 'Starter wählen',
    highlight: false,
  },
  {
    name: 'Business',
    price: '6.000',
    period: 'pro Jahr',
    description: 'Für wachsende Unternehmen mit vollem Funktionsumfang.',
    features: [
      'Alle 12+ Module',
      'Bis zu 25 Benutzer',
      'Multi-Standort',
      'PWA (mobil installierbar)',
      'Keycloak SSO',
      'Prioritäts-Support',
    ],
    cta: 'Business wählen',
    highlight: true,
  },
  {
    name: 'Enterprise',
    price: '12.000',
    period: 'pro Jahr',
    description: 'Für große Organisationen mit individuellen Anforderungen.',
    features: [
      'Alle 12+ Module',
      'Unbegrenzte Benutzer',
      'Multi-Standort & Multi-Tenant',
      'PWA (mobil installierbar)',
      'Keycloak SSO',
      'Custom Branding',
      'Dedizierter Ansprechpartner',
      'SLA & Onboarding',
    ],
    cta: 'Kontakt aufnehmen',
    highlight: false,
  },
];
---

<section id="preise" class="py-24 lg:py-32">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-sm font-medium text-brand-600 uppercase tracking-wider">Preise</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold">Transparent und fair</h2>
      <p class="mt-4 text-lg text-gray-500">
        Keine versteckten Kosten. Keine Einrichtungsgebühr. 30 Tage kostenlos testen.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      {plans.map((plan) => (
        <div class={`relative rounded-2xl p-8 ${plan.highlight ? 'bg-brand-700 text-white ring-2 ring-brand-700 scale-105' : 'bg-white border border-gray-200'}`}>
          {plan.highlight && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full bg-brand-500 text-white text-xs font-medium">
              Beliebteste Wahl
            </div>
          )}
          <h3 class={`text-xl font-bold ${plan.highlight ? 'text-white' : 'text-gray-900'}`}>{plan.name}</h3>
          <p class={`mt-1 text-sm ${plan.highlight ? 'text-brand-200' : 'text-gray-500'}`}>{plan.description}</p>

          <div class="mt-6 flex items-baseline gap-1">
            <span class={`text-4xl font-extrabold ${plan.highlight ? 'text-white' : 'text-gray-900'}`}>{plan.price} €</span>
            <span class={`text-sm ${plan.highlight ? 'text-brand-200' : 'text-gray-400'}`}>{plan.period}</span>
          </div>

          <ul class="mt-8 space-y-3">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class={`w-5 h-5 shrink-0 mt-0.5 ${plan.highlight ? 'text-brand-200' : 'text-brand-600'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class={`text-sm ${plan.highlight ? 'text-brand-100' : 'text-gray-600'}`}>{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href="#kontakt"
            class={`mt-8 block w-full py-3 rounded-xl text-center font-semibold text-sm transition-colors ${
              plan.highlight
                ? 'bg-white text-brand-700 hover:bg-brand-50'
                : 'bg-brand-700 text-white hover:bg-brand-800'
            }`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
