---
---

<section id="kontakt" class="py-24 lg:py-32 bg-brand-700">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-white">Bereit, Ihre Prozesse zu digitalisieren?</h2>
    <p class="mt-4 text-lg text-brand-200">
      Starten Sie mit einer kostenlosen 30-Tage-Testphase. Kein Risiko, keine Verpflichtung.
    </p>

    <div class="mt-10 bg-white/10 backdrop-blur-sm rounded-2xl p-8 text-left">
      <form class="space-y-4" action="mailto:info@vertoo.de" method="POST" enctype="text/plain">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-brand-200 mb-1">Vorname</label>
            <input type="text" name="vorname" class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-brand-300 text-sm focus:outline-none focus:ring-2 focus:ring-white/30" placeholder="Max" />
          </div>
          <div>
            <label class="block text-sm font-medium text-brand-200 mb-1">Nachname</label>
            <input type="text" name="nachname" class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-brand-300 text-sm focus:outline-none focus:ring-2 focus:ring-white/30" placeholder="Mustermann" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-brand-200 mb-1">E-Mail</label>
          <input type="email" name="email" class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-brand-300 text-sm focus:outline-none focus:ring-2 focus:ring-white/30" placeholder="max@firma.de" />
        </div>
        <div>
          <label class="block text-sm font-medium text-brand-200 mb-1">Unternehmen</label>
          <input type="text" name="firma" class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-brand-300 text-sm focus:outline-none focus:ring-2 focus:ring-white/30" placeholder="Firma GmbH" />
        </div>
        <div>
          <label class="block text-sm font-medium text-brand-200 mb-1">Nachricht (optional)</label>
          <textarea name="nachricht" rows="3" class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-brand-300 text-sm focus:outline-none focus:ring-2 focus:ring-white/30 resize-none" placeholder="Welche Module interessieren Sie?"></textarea>
        </div>
        <button type="submit" class="w-full py-3.5 rounded-xl bg-white text-brand-700 font-semibold text-sm hover:bg-brand-50 transition-colors">
          Kostenlos testen
        </button>
        <p class="text-xs text-brand-300 text-center">30 Tage kostenlos. Keine Kreditkarte erforderlich.</p>
      </form>
    </div>
  </div>
</section>
