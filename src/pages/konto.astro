---
import '../styles/global.css';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Anmelden bei Vertoo ERP" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>Anmelden – Vertoo ERP</title>
  </head>
  <body class="bg-gray-50 font-sans antialiased min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-sm">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-2.5">
          <div class="w-10 h-10 rounded-xl bg-brand-700 flex items-center justify-center">
            <span class="text-white font-bold text-lg">V</span>
          </div>
          <span class="text-2xl font-bold text-gray-900">Vertoo</span>
        </a>
        <p class="mt-2 text-sm text-gray-500">Melden Sie sich in Ihrem Konto an</p>
      </div>

      <!-- Login Card -->
      <div class="bg-white rounded-2xl shadow-lg shadow-gray-200/50 border border-gray-200 p-8">
        <form class="space-y-5" onsubmit="return false;">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="email">E-Mail-Adresse</label>
            <input
              id="email"
              type="email"
              class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors"
              placeholder="max@firma.de"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="password">Passwort</label>
            <input
              id="password"
              type="password"
              class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors"
              placeholder="••••••••"
            />
          </div>

          <div class="flex items-center justify-between">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-brand-600 focus:ring-brand-500" />
              <span class="text-sm text-gray-600">Angemeldet bleiben</span>
            </label>
            <a href="#" class="text-sm text-brand-700 hover:text-brand-800 font-medium">Passwort vergessen?</a>
          </div>

          <button
            type="submit"
            class="w-full py-2.5 rounded-xl bg-brand-700 text-white font-semibold text-sm hover:bg-brand-800 transition-colors"
            onclick="document.getElementById('demo-hint').classList.remove('hidden'); return false;"
          >
            Anmelden
          </button>
        </form>

        <!-- Demo hint -->
        <div id="demo-hint" class="hidden mt-4 p-3 rounded-lg bg-amber-50 border border-amber-200 text-sm text-amber-700 text-center">
          Dies ist eine Demo-Ansicht. Der Login ist noch nicht aktiv.
        </div>
      </div>

      <!-- Footer -->
      <div class="mt-6 text-center">
        <p class="text-xs text-gray-400">
          Noch kein Konto? <a href="https://vertoo.de/#kontakt" class="text-brand-700 hover:underline font-medium">Kostenlos testen</a>
        </p>
        <p class="mt-4 text-xs text-gray-300">
          <a href="https://vertoo.de/impressum" class="hover:text-gray-500 transition-colors">Impressum</a>
          {' · '}
          <a href="https://vertoo.de/datenschutz" class="hover:text-gray-500 transition-colors">Datenschutz</a>
        </p>
      </div>
    </div>
  </body>
</html>
